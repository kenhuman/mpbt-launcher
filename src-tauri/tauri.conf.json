{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MPBT Launcher",
  "version": "0.2.4",
  "identifier": "com.mpbt.launcher",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3010",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "MPBT Launcher",
        "width": 780,
        "height": 520,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwODJFNkExQTNGMTlDODUKUldTRm5QR2pvZWFDZ1AyM21vck5WbWxNSUhaNC8xV1NUOTF2S2FMcXpnN0dQejc0alJ4UGp3ejcK",
      "endpoints": [
        "https://github.com/kenhuman/mpbt-launcher/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
