# Production defaults baked into the compiled launcher at build time.
# These values are NOT sensitive (they end up in the JS bundle), but are kept
# out of source control so they can be changed without a code commit.
#
# HOW TO USE:
#   Local production build:   copy this file to .env.production and fill in values
#   CI (GitHub Actions):      set PROD_SERVER and PROD_API_URL as repository secrets
#                             — the workflow reads them; no file is needed in CI

NEXT_PUBLIC_WEB_URL=https://your-web-host
